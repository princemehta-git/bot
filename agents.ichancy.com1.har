            "text": ".wrapper-small-widget{text-align:center;margin:0 auto;width:100%}.wrapper-small-widget .title-small-widget{text-transform:capitalize;text-align:center;margin-bottom:15px;color:#3c4043;font-size:14px;font-weight:600;white-space:nowrap}.wrapper-small-widget .value-wrapper-small-widget{min-width:100px;display:inline-block;vertical-align:top;width:auto;border-radius:20px;border:solid 1px;text-align:center;padding:8px 10px;font-size:14px;white-space:nowrap}\n\n.mobileFilterButtonWrapper-bc{width:100%;padding-left:16px;padding-right:16px;padding-top:16px;margin-bottom:16px;position:relative;display:flex;justify-content:flex-end;align-items:center}.mobileFilterButtonWrapper-bc button{font-size:14px;font-weight:600;line-height:1.36;text-align:center;color:#ffffff;text-transform:capitalize;height:28px !important;min-height:auto}.mobileFilterButtonWrapper-bc:after{content:'';position:absolute;top:0;left:16px;width:calc(100% - 32px);height:1px;background-color:rgba(0,0,0,0.1)}.mobileFilterTabResult-bc{width:100%}.mobileFilterTabResult-bc .tabs-head{padding-right:16px;padding-left:16px;margin-bottom:20px}.mobileFilterTabResult-bc .tabs-content-holder{padding:16px 0 0 !important;background-color:var(--background)}.mobileFilterTabResult-bc .tabs-content-holder>.paper{border-radius:20px 20px 0 0;margin-top:0 !important}.mobileFilterTabResult-bc .tabs-content-holder .filterMargin{margin-top:0 !important}.mobileFilterTabResult-bc .mediaStatistics-bc>.module-header+.paper{border-radius:0 !important;margin-top:1px}.mobileFilterTabResult-bc .module-header+.paper>.module-header{display:none}.mobileFilterTabResult-bc .module-title{text-transform:capitalize}.mobileFilterTabResult-bc .wrapper-small-widget{display:flex;justify-content:space-between;align-items:center}.mobileFilterTabResult-bc .title-small-widget{margin-bottom:0}.mobileFilterTabResult-bc .value-wrapper-small-widget{min-width:auto;height:25px;padding:0 10px;display:flex;justify-content:center;align-items:center;border-radius:6px;font-size:14px;font-weight:600;line-height:1.36;color:#da5cac}\n\n.row-separator-b{width:100%;display:flex;justify-content:space-between;align-items:center}.totalInnerPadding{padding:30px;width:100%;display:flex;justify-content:center;align-items:center}.paper+.filterMargin{margin:20px 0}.filterMargin+.paper{margin-top:20px}.dashboard-widgets-wrap .widget-holder .head{overflow:initial}.totalInnerPaddingWidget{padding:20px}.totalInnerPaddingWidget .grid-child{position:relative}.totalInnerPaddingWidget .grid-child:after{content:'';width:1px;height:80%;position:absolute;top:50%;right:0;transform:translateY(-50%);background:rgba(0,0,0,0.1)}.totalInnerPaddingWidget .grid-child:nth-child(6n):after,.totalInnerPaddingWidget .grid-child:last-child:after{display:none}.profitInnerPadding{padding:30px;width:100%}.profitInnerPadding .chart-lengend-block.mobile{overflow-x:auto;overflow-y:hidden}.topUsersGrid .card-list-col:first-child{grid-column:1/4}.dashboardLowerStatisticsEl-bc .chart-lengend-block.mobile{max-width:none}.dashboardLowerStatisticsEl-bc .mediaStatistics-bc .charts-pie-chart{margin-top:2.4rem}.dashboardLowerStatisticsEl-bc .module-header.p-top{box-shadow:none}\n\n"

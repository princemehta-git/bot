# ── Web Admin Login ──
# Username and password for the web admin panel (http://localhost:3000/admin)
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── MySQL Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ichancy_bot

# ── Web / Webhook Server ──
# Port for the web admin panel and webhook server
WEB_PORT=3000

# ── Webhook vs Polling ──
# Set to true to use webhooks (less CPU); false for long-polling.
# When true, all bots share the same server. Each bot gets /webhook/<bot_id>.
USE_WEBHOOK=false
# Public HTTPS base URL for webhooks (no trailing slash). Required when USE_WEBHOOK=true.
WEBHOOK_DOMAIN=https://your-domain.com
# Optional: direct HTTPS. If set, server uses HTTPS with these cert files.
# WEBHOOK_SSL_CERT_PATH=/path/to/fullchain.pem
# WEBHOOK_SSL_KEY_PATH=/path/to/privkey.pem

# ── Spin Mini App ──
# HTTPS URL for the spin wheel mini app (required by Telegram). Use ngrok or a real domain for localhost.
# SPIN_SITE_URL=https://your-ngrok-or-domain.com
SPIN_SITE_URL=

# ── Syriatel Cash ──
# API base URL for Syriatel Cash (api key & pin are per-bot, stored in bots table)
SYRIATEL_API_BASE_URL=http://your-syriatel-api-host:3009
# Daily transfer limit per Syriatel account (in new currency, resets at 12AM bot timezone). Default: 5000
# SYRIATEL_DAILY_LIMIT is the actual backend limit used for calculations
# SYRIATEL_DAILY_LIMIT_DISPLAY is shown in messages to users/admins (defaults to SYRIATEL_DAILY_LIMIT if not set)
SYRIATEL_DAILY_LIMIT=5000
SYRIATEL_DAILY_LIMIT_DISPLAY=5000

# ── Currency ──
# Wallet currency multiple for Syriatel and ShamCash SYP: deposit amount * this = wallet credit; withdraw wallet amount / this = send via API (default 100)
OLD_CURRENCY_MULTIPLE=100

# ── ShamCash ──
# If account_address is in whitelist → use URL 1, else URL 2 (same payload/query/response)
# Comma-separated addresses that use URL 1
SHAMCASH_WHITELIST_ADDRESSES=
# URL 1 (whitelisted addresses)
SHAMCASH_BALANCE_API_URL=
SHAMCASH_TRANSACTION_API=
# URL 2 (other addresses — different service, same API structure)
SHAMCASH_BALANCE_API_URL_ALT=
SHAMCASH_TRANSACTION_API_ALT=
# ShamCash API debug logs (calling URL, response status, body) — set to true to debug 404s
SHAMCASH_API_DEBUG=false

# ── OxaPay ──
# General API keys (comma-separated; rotated on failure — used for swap/rate endpoints)
# Get from: https://oxapay.com → Developer → API Keys → General Key
OXAPAY_GENERAL_API_KEYS=

# ── Bot Configuration ──
# All bot-specific settings (token, channel, credentials, limits, etc.)
# are stored in the `bots` table in MySQL.
# Use the web admin panel to add and configure bots.
# Or manually: INSERT INTO bots (bot_id, bot_token, ...) VALUES ('mybot', 'TOKEN', ...);
